# dry-run is safe and produces deterministic proof logs without spending funds.
# live uses SAP mainnet and Ace x402 payments.
AGENT_MODE=dry-run

AGENT_NAME=Probeur
AGENT_DESCRIPTION=Probeur autonomously discovers SAP tools, validates them with Sentinel, consumes Ace Data Cloud services, and records x402/escrow payment proofs.
RUN_INTERVAL_SECONDS=3600
MAX_TOOLS_PER_RUN=5

# OOBE / SAP
SAP_CLUSTER=mainnet-beta
SAP_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_KEY
# Optional fallback for transaction submission if the configured SAP RPC is lagging.
SAP_SEND_RPC_URL=https://api.mainnet-beta.solana.com
SAP_AGENT_KEYPAIR_PATH=keys/agent.json
SYNAPSE_SENTINEL_WALLET=Ccr2yK3hLALU4p8oNRqrh4dGuvPJTth5KCLMio8cE1ph

# Ace x402 on Solana
# Fund this wallet with USDC/SOL before enabling live mode.
ACE_X402_NETWORK=solana
X402B_SOLANA_PAYER_PRIVATE_KEY=base58-private-key

# Optional live Ace service models/endpoints. The code is defensive because
# Ace's service catalog can evolve.
ACE_OPENAI_MODEL=gpt-4o-mini

# Configure these to match the exact services enabled in your Ace account.
# Defaults are chosen from public Ace examples/repos and can be changed without
# touching the agent loop.
ACE_SERVICE_SUMMARY=ai-chat
ACE_SERVICE_RESEARCH=google-search
ACE_SERVICE_RANKING=github

# SAP escrow settings for live mode.
SAP_ESCROW_PRICE_PER_CALL_LAMPORTS=1000000
SAP_ESCROW_INITIAL_DEPOSIT_LAMPORTS=10000000
SAP_ESCROW_MAX_CALLS=10
